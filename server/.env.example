INTERSWITCH_PAY_ITEM_ID=
# Passport OAuth lives on a separate host from the main API
INTERSWITCH_PASSPORT_BASE_URL=https://apps.qa.interswitchng.com
# Merchant Wallet (QTB) — escrow is not available; use merchant wallets instead
INTERSWITCH_WALLET_BASE_URL=https://merchant-wallet.k8.isw.la/merchant-wallet
# Collections / payments API base (QA: https://qa.interswitchng.com)
INTERSWITCH_BASE_URL=https://qa.interswitchng.com
# Static Bearer token for the virtual account callback (sandbox only — not the OAuth token)
INTERSWITCH_CALLBACK_TOKEN=